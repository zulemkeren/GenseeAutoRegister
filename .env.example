# ===== WAJIB =====

# API key dari https://2captcha.com (daftar -> top up -> copy key)
TWOCAPTCHA_API_KEY=isi_disini

# Kode referral yang mau dipake
REFERRAL_CODE=W3EWKVAJ (Ganti ke kode reffmu)


# ===== OPSIONAL: residential proxy =====
# Kalo gak pake proxy, biarin di-comment (#). Script tetep jalan, tapi
# semua signup pake IP lo - jangan banyak-banyak biar gak kena flag.
#
# Kalo pake proxy, hapus tanda # di 3 line di bawah dan isi credentials lo:

#PROXY_HOST=host.proxyprovider.com:port
#PROXY_USER=your_proxy_username
#PROXY_PASS=your_proxy_password

# Opsional banget - kalo provider proxy lo butuh region modifier:
#PROXY_REGION=us


# ===== OPSIONAL: locale nama =====
# Default en_US (nama Amerika, cocok kalo proxy juga US).
# Pilihan lain: id_ID (Indonesia), en_GB (UK), de_DE (Jerman), ja_JP (Jepang), dll.
#NAME_LOCALE=en_US
